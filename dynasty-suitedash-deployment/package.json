{
  "name": "dynasty-suitedash-deployment",
  "version": "1.0.0",
  "description": "Dynasty Empire - Multi-niche directory business factory powered by SuiteDash + n8n + AiTable",
  "private": true,
  "scripts": {
    "setup:aitable": "node scripts/setup-aitable.js",
    "bootstrap:aitable:discover": "node scripts/aitable-discover.js",
    "setup:verify": "node scripts/verify-connections.js",
    "setup:niche": "node scripts/deploy-niche.js",
    "import:n8n": "node scripts/import-n8n-workflows.js",
    "dashboard:dev": "cd dashboard && node server.js",
    "dashboard:build": "cd dashboard && npx next build",
    "test": "node tests/test-workflows.js && node tests/test-niche-configs.js",
    "test:agents": "node tests/test-agents.js",
    "test:api": "node tests/test-connections.js",
    "test:all": "npm test && npm run test:agents",
    "test:webhook": "node scripts/test-webhook.js",
    "emergency:stop": "node scripts/emergency-stop.js pause",
    "emergency:resume": "node scripts/emergency-stop.js resume",
    "emergency:status": "node scripts/emergency-stop.js status"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "dotenv": "^16.4.5",
    "openai": "^4.52.0",
    "stripe": "^15.0.0"
  },
  "devDependencies": {
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "recharts": "^2.12.0",
    "tailwindcss": "^3.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
